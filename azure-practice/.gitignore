# Terraform .gitignore

# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan

# Sensitive variable files
*.tfvars
*.tfvars.json

# Ignore lock file if you don’t want to commit provider versions
# (many teams DO commit this for reproducibility)
# terraform.lock.hcl
